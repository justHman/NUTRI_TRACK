{
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": true
  },
  "github.copilot.inlineSuggest.enable": true,
  "github.copilot.suggestionActions.enabled": true,
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.followUps": true,
  "github.copilot.chat.localeOverride": "auto",
  "github.copilot.chat.codebase.enabled": true,
  "github.copilot.chat.scopeSelection": true,
  "github.copilot.chat.codebase.useFileTree": true,
  "github.copilot.chat.codebase.maxFiles": 200,
  "chat.mcp.discovery": {
    "enabled": true
  },
  "chat.mcp.serverSampling": {
    ".github/.mcp.json: fetch": {
      "allowedModels": [
        "copilot/auto",
        "claude-code/claude-haiku-4.5",
        "copilot/claude-haiku-4.5",
        "copilotcli/claude-haiku-4.5",
        "copilot/gemini-2.5-pro",
        "copilot/gemini-3-flash-preview",
        "copilot/gemini-3-pro-preview",
        "copilotcli/gemini-3-pro-preview",
        "copilot/gemini-3.1-pro-preview",
        "copilot/gpt-4o",
        "copilot/gpt-5.2",
        "copilotcli/gpt-5.2",
        "copilot/gpt-5.2-codex",
        "copilotcli/gpt-5.2-codex",
        "copilot/gpt-5.3-codex",
        "copilotcli/gpt-5.3-codex",
        "copilot/gpt-5.4-mini",
        "copilot/grok-code-fast-1",
      ]
    }
  },
  "github.copilot.chat.tools.enabled": true,
  "github.copilot.chat.tools.autoApprove": false,
  "github.copilot.chat.promptFiles": true,
  "github.copilot.chat.useWorkspaceInstructions": true,
  "github.copilot.chat.history.enabled": true,
  "github.copilot.chat.memory.enabled": true,
  "github.copilot.advanced": {
    "inlineSuggestCount": 3
  },
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python.terminal.activateEnvironment": true,
  "python.envFile": "${workspaceFolder}/config/.env",
  "python.analysis.typeCheckingMode": "strict",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.extraPaths": [
    "${workspaceFolder}"
  ],
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.indexing": true,
  "python.linting.enabled": false,
  "ruff.enable": true,
  "ruff.lint.enable": true,
  "ruff.format.enable": true,
  "editor.formatOnSave": true,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "python.debugpy.justMyCode": true,
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.autoTestDiscoverOnSaveEnabled": true,
  "python.testing.pytestArgs": [
    "tests",
    "-q"
  ],
  "editor.inlayHints.enabled": "on",
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true
  },
  "chat.mcp.discovery.enabled": {
    "claude-desktop": true,
    "windsurf": true,
    "cursor-global": true,
    "cursor-workspace": true
  },
  "chat.mcp.access": "all"
}