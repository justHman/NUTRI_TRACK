{
    "tools": [
        {
            "toolSpec": {
                "name": "get_batch",
                "description": "Fetch nutritional information and ingredients for multiple food items at once in a single batch.",
                "inputSchema": {
                    "json": {
                        "type": "object",
                        "properties": {
                            "items": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "name": {
                                            "type": "string",
                                            "description": "Name of the food item"
                                        },
                                        "weight": {
                                            "type": "number",
                                            "description": "Weight in grams"
                                        }
                                    },
                                    "required": [
                                        "name",
                                        "weight"
                                    ]
                                }
                            }
                        },
                        "required": [
                            "items"
                        ]
                    }
                }
            }
        }
    ]
}